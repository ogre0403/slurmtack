# Required
LISTEN_ADDR=:8080
DB_PATH=/data/slurmtack.db

# Auth (optional — random key generated at startup if unset; set explicitly to preserve sessions across restarts)
# JWT_SIGNING_KEY=your-signing-key-here

# RabbitMQ
AMQP_URL=amqp://guest:guest@rabbitmq:5672/

# Slurm
SLURM_API_URL=http://slurm-head:6820
SLURM_JWT_TOKEN=
SLURM_API_USER=cloud-user          # Slurm user for job submit/cancel/node read (default: cloud-user)
SLURM_ADMIN_USER=root              # Slurm user for drain/resume (default: SLURM_API_USER)
SLURM_ADMIN_JWT_TOKEN=             # JWT for drain/resume (default: SLURM_JWT_TOKEN)
# SLURM_SIF_PATH is a home-relative directory (resolved as /home/<workload-user>/<path>)
SLURM_SIF_PATH=.slurmtack
# SLURM_SIF_FILE is the default SIF filename
SLURM_SIF_FILE=placeholder.sif
# SLURM_CLOUD_PARTITION=cloud

# SLURM_ADMIN_TOKEN_LIFESPAN is the lifespan (seconds) of SSH-minted admin
# tokens; only used when SSH_LOGIN_NODE is set. Defaults to 600.
SLURM_ADMIN_TOKEN_LIFESPAN=86400

# OpenStack
OS_AUTH_URL=http://keystone:5000/v3
OS_PROJECT_NAME=
OS_USERNAME=
OS_PASSWORD=
OS_USER_DOMAIN_NAME=Default
OS_PROJECT_DOMAIN_NAME=Default


# SSH runner
SSH_USER=
SSH_PORT=22
SSH_OPTIONS=StrictHostKeyChecking=accept-new ConnectTimeout=5
SSH_PRIVATE_KEY_PATH=/run/secrets/slurmtack-ssh-key
SSH_POLL_INTERVAL=10s
SSH_POLL_TIMEOUT=10m

# SSH_LOGIN_NODE enables SSH-based admin token renewal. When set, the daemon
# runs `scontrol token username=<SLURM_ADMIN_USER> lifespan=<...>` on this host
# over SSH to mint short-lived admin tokens. Requires the SSH transport above to
# be valid and the SSH identity to be able to run `scontrol token` (directly or
# via passwordless sudo). Recommended for long-running deployments.
SSH_LOGIN_NODE=login-01

# GPU passthrough scripts. When GPU_PASSTHROUGH_SCRIPT_DIR points at a compatible
# passthrough bundle directory, the daemon stages reconfigure.sh / verify.sh
# (plus lib.sh) to the target node with scp and runs them over SSH during a
# switch: enable+verify for slurm_to_openstack, disable+verify for
# openstack_to_slurm. Leave unset to skip the integration and run the scripts
# manually. REMOTE_STAGING_DIR is the base remote dir scripts are copied into
# (defaults to /tmp).
#
# Two repo-owned bundles are available:
#   scripts/gpu-passthrough  — production bundle; requires NVIDIA GPU + VFIO.
#   scripts/fake-passthrough — TEST-ONLY; succeeds as a no-op on any host.
#                              Use in non-GPU CI/test environments to validate
#                              the orchestration flow. Never use in production.
GPU_PASSTHROUGH_SCRIPT_DIR=/slurmtack/scripts/gpu-passthrough
REMOTE_STAGING_DIR=/tmp
