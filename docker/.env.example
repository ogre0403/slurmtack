# Required
API_TOKEN=changeme
LISTEN_ADDR=:8080
DB_PATH=/data/slurmtack.db

# Slurm (optional)
# SLURM_API_URL=http://slurm-head:6820
# SLURM_JWT_TOKEN=
# PLACEHOLDER_SIF_PATH=/shared/images/placeholder-agent.sif

# OpenStack (optional)
# OS_AUTH_URL=http://keystone:5000/v3
# OS_PROJECT_NAME=
# OS_USERNAME=
# OS_PASSWORD=
# OS_USER_DOMAIN_NAME=Default
# OS_PROJECT_DOMAIN_NAME=Default

# RabbitMQ (optional)
# AMQP_URL=amqp://guest:guest@localhost:5672/

# SSH runner (optional)
# SSH_USER=
# SSH_PORT=22
# SSH_OPTIONS=StrictHostKeyChecking=accept-new ConnectTimeout=5

# Reachability polling
# SSH_POLL_INTERVAL=10s
# SSH_POLL_TIMEOUT=10m
